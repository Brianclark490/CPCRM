{
      "name": "cpcrm",
      "lockfileVersion": 3,
      "requires": true,
      "packages": {
            "": {
                  "name": "cpcrm",
                  "workspaces": [
                        "apps/*",
                        "packages/*"
                  ],
                  "engines": {
                        "node": ">=20.0.0",
                        "npm": ">=10.0.0"
                  }
            },
            "apps/api": {
                  "name": "@cpcrm/api",
                  "version": "0.0.0"
            },
            "apps/web": {
                  "name": "@cpcrm/web",
                  "version": "0.0.0"
            },
            "node_modules/@cpcrm/api": {
                  "resolved": "apps/api",
                  "link": true
            },
            "node_modules/@cpcrm/config": {
                  "resolved": "packages/config",
                  "link": true
            },
            "node_modules/@cpcrm/types": {
                  "resolved": "packages/types",
                  "link": true
            },
            "node_modules/@cpcrm/ui": {
                  "resolved": "packages/ui",
                  "link": true
            },
            "node_modules/@cpcrm/web": {
                  "resolved": "apps/web",
                  "link": true
            },
            "packages/config": {
                  "name": "@cpcrm/config",
                  "version": "0.0.0"
            },
            "packages/types": {
                  "name": "@cpcrm/types",
                  "version": "0.0.0"
            },
            "packages/ui": {
                  "name": "@cpcrm/ui",
                  "version": "0.0.0"
            }
      }
}

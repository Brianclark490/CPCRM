# =============================================================================
# CPCRM Web — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your local environment.
# Never commit .env.local to source control.
# See docs/configuration.md for full guidance on configuration management.
# =============================================================================

# --- Authentication -----------------------------------------------------------

# Descope Project ID (required)
# Find this in the Descope Console: https://app.descope.com/settings/project
# Format: P<alphanumeric string>
# This value is embedded in the frontend bundle and is not a secret.
VITE_DESCOPE_PROJECT_ID=P_your_project_id_here

# --- API ----------------------------------------------------------------------

# Base URL of the backend API (optional, defaults to http://localhost:3001 via Vite proxy)
VITE_API_BASE_URL=http://localhost:3001

# --- Observability ------------------------------------------------------------

# Azure Application Insights connection string (optional in local dev)
# Required in deployed Azure environments for browser-side telemetry.
# Injected at build time via GitHub Actions; do not commit to source control.
# VITE_APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

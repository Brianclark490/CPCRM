# Descope Project ID (required)
# Find this in the Descope Console: https://app.descope.com/settings/project
# Format: P<alphanumeric string>
# This value is safe to expose in the browser (it is a public project identifier).
VITE_DESCOPE_PROJECT_ID=P_your_project_id_here

# API base URL (optional, defaults to same origin when using Vite proxy)
VITE_API_BASE_URL=http://localhost:3001

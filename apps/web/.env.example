# ─── API ──────────────────────────────────────────────────────────────────────
# Base URL for the backend API (no trailing slash)
VITE_API_URL=http://localhost:3000

# ─── Auth (Descope) ───────────────────────────────────────────────────────────
# Descope project ID – find this in the Descope console
VITE_DESCOPE_PROJECT_ID=your-descope-project-id

# ─── App ──────────────────────────────────────────────────────────────────────
# Environment identifier: development | staging | production
VITE_APP_ENV=development

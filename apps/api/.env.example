# =============================================================================
# CPCRM API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your local environment.
# Never commit .env to source control.
# See docs/configuration.md for full guidance on configuration management.
# =============================================================================

# --- Authentication -----------------------------------------------------------

# Descope Project ID (required)
# Find this in the Descope Console: https://app.descope.com/settings/project
# Format: P<alphanumeric string>
# In deployed environments, source from Azure Key Vault.
DESCOPE_PROJECT_ID=P_your_project_id_here

# --- Server -------------------------------------------------------------------

# Port the API server listens on (optional, defaults to 3001)
PORT=3001

# Allowed CORS origin for the frontend (optional, defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

# --- Logging ------------------------------------------------------------------

# Minimum log level: trace | debug | info | warn | error | fatal
# Defaults to 'info'. Use 'debug' for verbose local output.
LOG_LEVEL=info

# --- Observability ------------------------------------------------------------

# Azure Application Insights connection string (optional in local dev)
# Required in deployed Azure environments for centralised logging and APM.
# Store in Azure Key Vault; never commit to source control.
# APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=...;IngestionEndpoint=...

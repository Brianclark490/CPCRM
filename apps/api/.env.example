# Descope Project ID (required)
# Find this in the Descope Console: https://app.descope.com/settings/project
# Format: P<alphanumeric string>
DESCOPE_PROJECT_ID=P_your_project_id_here

# Port the API server listens on (optional, defaults to 3001)
PORT=3001

# Allowed CORS origin for the frontend (optional, defaults to http://localhost:5173)
CORS_ORIGIN=http://localhost:5173

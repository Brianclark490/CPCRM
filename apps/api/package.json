{
  "name": "@cpcrm/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc && node -e \"require('node:fs').cpSync('src/db/migrations','dist/db/migrations',{recursive:true})\" && npm run generate-openapi",
    "start": "node dist/index.js",
    "test": "vitest run",
    "lint": "echo 'lint not yet implemented'",
    "typecheck": "tsc --noEmit",
    "generate-openapi": "node dist/generateOpenAPI.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:types": "kysely-codegen --dialect postgres --url $DATABASE_URL --out-file src/db/kysely.types.ts"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@descope/node-sdk": "^1.10.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "kysely": "^0.28.16",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/pino-http": "^6.1.0",
    "kysely-codegen": "^0.20.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
